# ===== Core settings =====
LAST30_OUTPUT_DIR=outputs
LAST30_CACHE_DIR=cache
LAST30_DB_PATH=cache/last30free.sqlite
LAST30_REQUEST_TIMEOUT_SECONDS=20
LAST30_DEFAULT_DAYS=30
LAST30_MAX_ITEMS_PER_SOURCE=25
LAST30_USER_AGENT=last30free/0.1.0

# ===== Reddit =====
REDDIT_BASE_URL=https://www.reddit.com
REDDIT_SEARCH_LIMIT=25
REDDIT_COMMENT_LIMIT=5

# ===== Hacker News (Algolia) =====
HN_ALGOLIA_BASE_URL=https://hn.algolia.com/api/v1
HN_SEARCH_LIMIT=25
HN_COMMENT_LIMIT=10

# ===== YouTube / yt-dlp =====
YOUTUBE_SEARCH_LIMIT=20
YOUTUBE_SUB_LANGS=en.*,en
YOUTUBE_WRITE_AUTO_SUBS=true
YOUTUBE_WRITE_SUBS=true

# ===== X / Twitter via twscrape =====
# Optional. Leave blank if you want X disabled for now.
AUTH_TOKEN=
CT0=
X_SEARCH_LIMIT=20
X_ENABLE=true

# ===== Instagram =====
# Required for Instagram scraping. Without it Instagram is skipped.
# Get it: log into Instagram in Chrome → DevTools (F12) → Application → Cookies → instagram.com → sessionid
INSTAGRAM_SESSION_ID=
INSTAGRAM_SEARCH_LIMIT=20
INSTAGRAM_ENABLE=true

# ===== TikTok =====
# No credentials needed — TikTok scraping uses a visible browser automatically.
TIKTOK_SEARCH_LIMIT=20
TIKTOK_ENABLE=true
